{
  "name": "codegraph-mcp",
  "displayName": "CodeGraph MCP",
  "description": "Provides code analysis tools using Model Context Protocol",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
      "configuration": {
      "title": "CodeGraph MCP",
      "properties": {
        "codegraph.mcpPort": {
          "type": "number",
          "default": 6010,
          "description": "Port number for the MCP SSE server"
        }
      }
    }
  },
  "repository": {
    "repository": "github:andreyvgavrilov/CodeGraph_MCP"
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run bundle -- --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/sinon": "^21.0.1",
    "@types/supertest": "^7.2.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vscode/test-electron": "^2.4.0",
    "chai": "^6.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/express": "^4.17.0",
    "express": "^4.18.0",
    "zod": "^3.25.76"
  }
}
